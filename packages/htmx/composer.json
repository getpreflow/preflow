{
    "name": "preflow/htmx",
    "description": "Preflow HTMX — hypermedia driver, component tokens, component endpoint",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-sodium": "*",
        "preflow/core": "^0.1 || @dev",
        "preflow/components": "^0.1 || @dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "twig/twig": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Preflow\\Htmx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Preflow\\Htmx\\Tests\\": "tests/"
        }
    }
}
