{
    "name": "preflow/auth",
    "description": "Preflow auth — pluggable guards, session auth, API tokens, password hashing",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "preflow/core": "^0.1 || @dev",
        "preflow/data": "^0.1 || @dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Preflow\\Auth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Preflow\\Auth\\Tests\\": "tests/"
        }
    }
}
