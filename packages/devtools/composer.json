{
    "name": "preflow/devtools",
    "description": "Preflow devtools — CLI commands, dev inspector",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "preflow/core": "^0.1 || @dev",
        "preflow/routing": "^0.1 || @dev",
        "preflow/data": "^0.1 || @dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Preflow\\DevTools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Preflow\\DevTools\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/preflow"]
}
