<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"><title>{{ record.title }}</title></head>
<body>
    <article>
        <h1>{{ record.title }}</h1>
        {% for name, html in rendered %}
            {% if name != 'title' %}<div class="folio-field folio-field-{{ name }}">{{ html|raw }}</div>{% endif %}
        {% endfor %}
    </article>
</body>
</html>
