{
    "name": "preflow/folio",
    "description": "Folio — drop-in CMS for Preflow: shipped admin, JSON content types, slug rendering",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "preflow/core": "^0.1 || @dev",
        "preflow/data": "^0.1 || @dev",
        "preflow/view": "^0.1 || @dev",
        "preflow/routing": "^0.1 || @dev",
        "preflow/form": "^0.1 || @dev",
        "preflow/validation": "^0.1 || @dev",
        "nyholm/psr7": "^1.8",
        "symfony/html-sanitizer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "Preflow\\Folio\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": {
            "Preflow\\Folio\\Tests\\": "tests/"
        }
    }
}
