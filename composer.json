{
    "name": "preflow/monorepo",
    "description": "Preflow framework monorepo — development only",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "illuminate/filesystem": "^12.56",
        "illuminate/view": "^12.56",
        "phpunit/phpunit": "^11.0",
        "preflow/blade": "@dev",
        "preflow/components": "@dev",
        "preflow/core": "@dev",
        "preflow/data": "@dev",
        "preflow/devtools": "@dev",
        "preflow/htmx": "@dev",
        "preflow/i18n": "@dev",
        "preflow/routing": "@dev",
        "preflow/testing": "@dev",
        "preflow/twig": "@dev",
        "preflow/view": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/components",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/core",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/data",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/htmx",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/routing",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/view",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/blade",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/twig",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/i18n",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/testing",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/devtools",
            "options": { "symlink": true }
        }
    ],
    "autoload": {},
    "autoload-dev": {
        "psr-4": {
            "App\\": "packages/skeleton/app/",
            "Tests\\": "packages/skeleton/tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
